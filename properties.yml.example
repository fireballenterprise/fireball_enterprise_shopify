---
# fireball_enterprise_shopify Properties
# Central configuration for all scripts and automation.
#
# properties.yml is gitignored (machine-specific local paths) and has no auto-generation task in
# this repo yet — copy this file to properties.yml and fill in your own values.

repo:
  local: "$HOME/path/to/this/repo"
  remote: "github.com/<your-username>/<your-repo-name>"

shopify:
  local_config: "tmp/.shopify/config.yml"

# Where /sync-setup pulls template updates from.
template:
  local: "$HOME/path/to/template_shopify"
  remote: "github.com/fireballenterprise/template_shopify"
